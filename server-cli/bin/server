#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PROGRAM_NAME="$(basename "$0")"

readonly COLOR_BLUE='\033[0;34m'
readonly COLOR_GREEN='\033[0;32m'
readonly COLOR_YELLOW='\033[1;33m'
readonly COLOR_RED='\033[0;31m'
readonly COLOR_NC='\033[0m'

info() {
  printf "${COLOR_BLUE}==>${COLOR_NC} %s\n" "$1"
}

success() {
  printf "${COLOR_GREEN}✔${COLOR_NC} %s\n" "$1"
}

error_msg() {
  printf "${COLOR_RED}✖${COLOR_NC} %s\n" "$1" >&2
}

show_help() {
  printf "\n"
  printf "  Server CLI\n\n"
  printf "  Usage:\n"
  printf "    %s <command> [args]\n\n" "$PROGRAM_NAME"
  printf "  Commands:\n"
  printf "    deploy <app>   Update app repo and restart containers\n"
  printf "    logs <app>     Follow docker compose logs for app\n"
  printf "    status         Show running containers\n\n"
  printf "  Examples:\n"
  printf "    %s deploy my-app\n" "$PROGRAM_NAME"
  printf "    %s logs my-app\n" "$PROGRAM_NAME"
  printf "    %s status\n\n" "$PROGRAM_NAME"
}

if [[ $# -lt 1 || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  show_help
  exit 0
fi

COMMAND="$1"
shift

case "$COMMAND" in
deploy)
  if [[ $# -ne 1 ]]; then
    error_msg "deploy expects exactly 1 argument: <app>"
    exit 1
  fi
  info "Deploying app: $1"
  bash "$ROOT_DIR/scripts/deploy.sh" "$1"
  success "Deploy command finished"
  ;;

logs)
  if [[ $# -ne 1 ]]; then
    error_msg "logs expects exactly 1 argument: <app>"
    exit 1
  fi
  info "Streaming logs for app: $1"
  bash "$ROOT_DIR/scripts/logs.sh" "$1"
  ;;

status)
  if [[ $# -ne 0 ]]; then
    error_msg "status does not accept arguments"
    exit 1
  fi
  bash "$ROOT_DIR/scripts/status.sh"
  ;;

*)
  error_msg "unknown command: $COMMAND"
  error_msg "Run '$PROGRAM_NAME --help' for usage"
  exit 1
  ;;
esac
